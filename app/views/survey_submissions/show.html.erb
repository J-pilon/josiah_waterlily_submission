<div class="max-w-4xl mx-auto p-6">
  <div class="mb-8">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-3xl font-bold text-gray-900">
        Survey Submission
      </h1>
      <div class="flex space-x-3">
        <%= link_to "New Submission", new_survey_submission_path, 
            class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
      </div>
    </div>

    <!-- Survey Information -->
    <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm mb-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">
        <%= @survey_submission.survey.title %>
      </h2>
      <p class="text-gray-600 mb-4">
        <%= @survey_submission.survey.description %>
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm text-gray-500">
        <div>
          <span class="font-medium">Submission ID:</span>
          <span class="ml-2">#<%= @survey_submission.id %></span>
        </div>
        <div>
          <span class="font-medium">Submitted:</span>
          <span class="ml-2"><%= @survey_submission.created_at.strftime("%B %d, %Y at %I:%M %p") %></span>
        </div>
        <div>
          <span class="font-medium">Questions:</span>
          <span class="ml-2"><%= @survey_submission.answers.count %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Questions and Answers -->
  <div class="space-y-6">
    <% @survey_submission.answers.includes(:question).each_with_index do |answer, index| %>
      <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
        <div class="mb-4">
          <h3 class="text-lg font-medium text-gray-900 mb-2">
            Question <%= index + 1 %>: <%= answer.question.title %>
          </h3>
          <p class="text-gray-600 text-sm">
            <%= answer.question.description %>
          </p>
        </div>

        <div class="bg-gray-50 rounded-lg p-4">
          <div class="flex items-start space-x-3">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-indigo-100 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-indigo-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                </svg>
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium text-gray-900 mb-1">
                Response:
              </div>
              <div class="text-gray-700">
                <% if answer.response.present? %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                    <%= answer.response %>
                  </span>
                <% else %>
                  <span class="text-gray-400 italic">No response provided</span>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <!-- Question Metadata -->
        <div class="mt-4 pt-4 border-t border-gray-100">
          <div class="flex justify-between items-center text-xs text-gray-500">
            <span>Question ID: <%= answer.question_id %></span>
            <span>Answer ID: <%= answer.id %></span>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
