<div class="max-w-4xl mx-auto p-6">
  <h1 class="text-3xl font-bold text-gray-900 mb-6">
    <%= @survey.title %>
  </h1>
  
  <p class="text-gray-600 mb-8">
    <%= @survey.description %>
  </p>

  <%= form_with model: @survey_submission, local: true, class: "space-y-8" do |form| %>
    <% if @survey_submission.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4 mb-6">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              Please correct the following errors:
            </h3>
            <div class="mt-2 text-sm text-red-700">
              <ul class="list-disc pl-5 space-y-1">
                <% @survey_submission.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div class="space-y-6">
      <% @survey.questions.each_with_index do |question, index| %>
        <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
          <div class="mb-4">
            <h3 class="text-lg font-medium text-gray-900 mb-2">
              Question <%= index + 1 %>: <%= question.title %>
            </h3>
            <p class="text-gray-600">
              <%= question.description %>
            </p>
          </div>

          <% 
            # Find the corresponding answer for this question
            answer = @survey_submission.answers.find { |a| a.question_id == question.id }
            answer ||= @survey_submission.answers.build(question: question)
          %>

          <%= form.fields_for :answers, answer do |answer_form| %>
            <%= answer_form.hidden_field :question_id %>
            
            <div class="space-y-3">
              <div>
                <%= answer_form.label :response, "Your Answer", class: "block text-sm font-medium text-gray-700 mb-2" %>
                <%= answer_form.text_area :response, 
                                          rows: 3,
                                          placeholder: "Please provide your response...",
                                          class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm #{answer.errors[:response].any? ? 'border-red-300' : ''}" %>

                <% if answer.errors[:response].any? %>
                  <div class="mt-2 text-sm text-red-600">
                    <% answer.errors[:response].each do |error| %>
                      <p><%= error %></p>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%= form.hidden_field :survey_id %>

    <div class="flex justify-end space-x-4 pt-6 border-t border-gray-200">
      <%= form.submit "Submit Survey", 
          class: "px-6 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    </div>
  <% end %>
</div>
